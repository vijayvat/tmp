{{- if .Values.externalSecret.enabled }}
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: {{ .Values.externalSecret.secretName }}
  namespace: {{ .Release.Namespace }}
spec:
  secretStoreRef:
    kind: {{ .Values.externalSecret.secretStoreRef.kind }}
    name: {{ .Values.externalSecret.secretStoreRef.name }}
  refreshInterval: 1h
  target:
    creationPolicy: Owner
    deletionPolicy: Retain
    name: {{ .Values.externalSecret.secretName }}
  data:
    - secretKey: github_app_id
      remoteRef:
        key: {{ .Values.externalSecret.remoteRef.appId }}
    - secretKey: github_app_installation_id  
      remoteRef:
        key: {{ .Values.externalSecret.remoteRef.installationId }}
    - secretKey: github_app_private_key
      remoteRef:
        key: {{ .Values.externalSecret.remoteRef.privateKey }}
{{- end }}

externalSecret:
  enabled: true
  secretName: "arc-github-credentials"
  secretStoreRef:
    name: "devopstools-secret-store"
    kind: "ClusterSecretStore"
  remoteRef:
    appId: "arc-github-app-id"
    installationId: "arc-github-app-installation-id" 
    privateKey: "arc-github-app-private-key"
